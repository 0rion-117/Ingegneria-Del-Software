@startuml sd_ModificaPassword
title <b>sd ModificaPassword</b>

actor "Studente" as Studente
boundary "GestioneProfilo" as GestioneProfilo
boundary "FormModificaPassword" as FormModificaPassword
control "GestioneModificaPasswordCtl" as GestioneModificaPasswordCtl
entity "Studente" as EntityStudente
boundary "PannelloErrore" as PannelloErrore
boundary "PannelloAvviso" as PannelloAvviso
boundary "DBMSBoundary" as DBMSBoundary
actor "DBMS" as DBMS

activate Studente

Studente -> GestioneProfilo : 1: ClickModificaPassword()
activate GestioneProfilo
GestioneProfilo -> GestioneModificaPasswordCtl : 1.1: AvviaModificaPassword()
activate GestioneModificaPasswordCtl

GestioneModificaPasswordCtl -> FormModificaPassword : 2: MostraFormModificaPassword()
activate FormModificaPassword

Studente -> FormModificaPassword : 3: InserisciDatiPassword(passwordCorrente, nuovaPassword, confermaNuovaPassword)
Studente -> FormModificaPassword : 4: ClickConferma()
FormModificaPassword -> GestioneModificaPasswordCtl : 4.1: InviaDatiPassword(passwordCorrente, nuovaPassword, confermaNuovaPassword)

GestioneModificaPasswordCtl -> GestioneModificaPasswordCtl : 5: passwordCorrenteCifrata = CriptaPassword(passwordCorrente)

GestioneModificaPasswordCtl -> DBMSBoundary : 6: RichiediVerificaPassword(idStudente, passwordCorrenteCifrata)
activate DBMSBoundary
DBMSBoundary -> DBMS : 6.1: querySelectPasswordStudente(idStudente, passwordCorrenteCifrata)
activate DBMS
DBMS --> DBMSBoundary : esitoVerificaPasswordCorrente
DBMSBoundary --> GestioneModificaPasswordCtl : esitoVerificaPasswordCorrente
deactivate DBMS
deactivate DBMSBoundary

alt 7: esitoVerificaPasswordCorrente = Falso
    GestioneModificaPasswordCtl -> PannelloErrore : 7.1: MostraPannelloErrore("Password non corretta")
    activate PannelloErrore
    Studente -> PannelloErrore : 7.2: ClickChiudi()
    PannelloErrore -> PannelloErrore : 7.3: ChiudiPannello()
    destroy PannelloErrore
    GestioneModificaPasswordCtl -> GestioneProfilo : 7.4: MostraGestioneProfilo()
else 8: esitoVerificaPasswordCorrente = Vero
    GestioneModificaPasswordCtl -> GestioneModificaPasswordCtl : 8.1: nuovaPasswordValida = ValidaNuovaPassword(passwordCorrente, nuovaPassword, confermaNuovaPassword)

    alt 9: nuovaPasswordValida = Falso
        GestioneModificaPasswordCtl -> PannelloErrore : 9.1: MostraPannelloErrore("Errore Password")
        activate PannelloErrore
        Studente -> PannelloErrore : 9.2: ClickChiudi()
        PannelloErrore -> PannelloErrore : 9.3: ChiudiPannello()
        destroy PannelloErrore
        GestioneModificaPasswordCtl -> GestioneProfilo : 9.4: MostraGestioneProfilo()
    else 10: nuovaPasswordValida = Vero
        GestioneModificaPasswordCtl -> GestioneModificaPasswordCtl : 10.1: passwordCifrata = CriptaPassword(nuovaPassword)
        GestioneModificaPasswordCtl -> EntityStudente : 10.2: SetPassword(passwordCifrata)
        activate EntityStudente
        deactivate EntityStudente

        GestioneModificaPasswordCtl -> DBMSBoundary : 11: RichiediAggiornamentoPassword(idStudente, passwordCifrata)
        activate DBMSBoundary
        DBMSBoundary -> DBMS : 11.1: queryUpdatePassword(idStudente, passwordCifrata)
        activate DBMS
        DBMS --> DBMSBoundary : esitoAggiornamentoPassword
        DBMSBoundary --> GestioneModificaPasswordCtl : esitoAggiornamentoPassword
        deactivate DBMS
        deactivate DBMSBoundary

        GestioneModificaPasswordCtl -> PannelloAvviso : 12: MostraPannelloAvviso("Modifica Avvenuta")
        activate PannelloAvviso
        Studente -> PannelloAvviso : 13: ClickChiudi()
        PannelloAvviso -> PannelloAvviso : 14: ChiudiPannello()
        destroy PannelloAvviso
        GestioneModificaPasswordCtl -> GestioneProfilo : 15: MostraGestioneProfilo()
    end
end

deactivate FormModificaPassword
deactivate GestioneModificaPasswordCtl
deactivate GestioneProfilo
deactivate Studente

@enduml