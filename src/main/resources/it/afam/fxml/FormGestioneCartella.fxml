<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.ViewFormGestioneCartella" styleClass="root">
    <padding><Insets top="42" right="42" bottom="42" left="42"/></padding>
    <center>
        <VBox alignment="CENTER" maxWidth="720" spacing="16" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="6">
                <Label text="Cartella" styleClass="form-title"/>
                <Label text="Scegli i contenuti da raggruppare" styleClass="form-subtitle"/>
            </VBox>
            <VBox maxWidth="680" spacing="10">
                <Label text="Nome Cartella" styleClass="field-label"/>
                <TextField fx:id="nomeCartellaField" maxWidth="Infinity" prefHeight="42" promptText="Nome Cartella"/>
                <Label text="Contenuti" styleClass="field-label"/>
                <ScrollPane fitToWidth="true" maxHeight="360" prefHeight="320" styleClass="content-preview">
                    <content>
                        <VBox fx:id="contenutiBox" spacing="8"/>
                    </content>
                </ScrollPane>
                <HBox alignment="CENTER" spacing="10">
                    <Button fx:id="confermaButton" maxWidth="Infinity" prefHeight="46" text="Conferma"
                            onAction="#ClickConferma" HBox.hgrow="ALWAYS" styleClass="primary-login-button"/>
                    <Button fx:id="salvaModificheButton" maxWidth="Infinity" prefHeight="46" text="Salva Modifiche"
                            onAction="#ClickSalvaModifiche" HBox.hgrow="ALWAYS" styleClass="primary-login-button"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
    <bottom>
    <HBox alignment="BOTTOM_LEFT" BorderPane.alignment="BOTTOM_LEFT">
        <Button text="Torna indietro" onAction="#ClickIndietro"/>
    </HBox>
    </bottom>
</BorderPane>
