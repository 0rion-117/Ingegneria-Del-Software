<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.ViewGestioneProfilo" styleClass="root">
    <padding><Insets top="42" right="42" bottom="42" left="42"/></padding>
    <center>
        <VBox alignment="CENTER" maxWidth="560" spacing="18" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="6">
                <Label text="Profilo" styleClass="form-title"/>
                <Label text="Dati principali dell'account studente" styleClass="form-subtitle"/>
            </VBox>
            <GridPane alignment="CENTER" hgap="16" maxWidth="520" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="280"/>
                </columnConstraints>
                <Label text="Username" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="usernameLabel" styleClass="profile-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="E-mail" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="emailLabel" styleClass="profile-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
            <VBox maxWidth="420" spacing="10">
                <Button maxWidth="Infinity" prefHeight="46" text="Modifica Password" onAction="#ClickModificaPassword"
                        styleClass="primary-login-button"/>
                <Separator/>
                <Button maxWidth="Infinity" prefHeight="46" text="Elimina Account" onAction="#SelezionaEliminaAccount"/>
                <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="42" promptText="Password"/>
                <Button maxWidth="Infinity" prefHeight="46" text="Conferma" onAction="#ClickConferma"
                        styleClass="primary-login-button"/>
            </VBox>
        </VBox>
    </center>
    <bottom>
    <HBox alignment="BOTTOM_LEFT" BorderPane.alignment="BOTTOM_LEFT">
        <Button text="Torna indietro" onAction="#ClickIndietro"/>
    </HBox>
    </bottom>
</BorderPane>
