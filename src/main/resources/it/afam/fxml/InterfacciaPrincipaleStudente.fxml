<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.ViewInterfacciaPrincipale" styleClass="root">
    <top>
        <HBox alignment="CENTER" spacing="16">
            <padding><Insets top="18" right="28" bottom="8" left="28"/></padding>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Portfolio" styleClass="form-title"/>
                <Label fx:id="studenteLabel" styleClass="form-subtitle"/>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="8">
                <Button text="Carica Nuovo Contenuto" onAction="#ClickCaricaNuovoContenuto"/>
                <Button text="Profilo" onAction="#ClickGestioneProfilo"/>
                <Button text="Cartelle" onAction="#ClickGestioneCartelle"/>
                <Button text="Logout" onAction="#ClickLogout"/>
            </HBox>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" maxWidth="980" spacing="10" BorderPane.alignment="CENTER">
            <ListView fx:id="contenutiList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="8">
            <padding><Insets top="8" right="28" bottom="22" left="28"/></padding>
            <Button text="Visualizza Contenuto" onAction="#ClickContenuto"/>
            <Button text="Modifica Contenuto" onAction="#ClickModificaContenuto"/>
            <Button text="Elimina Contenuto" onAction="#ClickEliminaContenuto"/>
        </HBox>
    </bottom>
</BorderPane>
