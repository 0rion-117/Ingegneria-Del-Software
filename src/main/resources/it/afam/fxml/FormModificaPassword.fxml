<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.ViewFormModificaPassword" styleClass="root">
    <padding><Insets top="42" right="42" bottom="42" left="42"/></padding>
    <center>
        <VBox alignment="CENTER" maxWidth="460" spacing="18" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="6">
                <Label text="Modifica password" styleClass="form-title"/>
                <Label text="Aggiorna la password dell'account" styleClass="form-subtitle"/>
            </VBox>
            <VBox maxWidth="420" spacing="10">
                <Label text="Password Corrente" styleClass="field-label"/>
                <PasswordField fx:id="passwordCorrenteField" maxWidth="Infinity" prefHeight="44" promptText="Password Corrente"/>
                <Label text="Nuova Password" styleClass="field-label"/>
                <PasswordField fx:id="nuovaPasswordField" maxWidth="Infinity" prefHeight="44" promptText="Nuova Password"/>
                <Label text="Conferma Nuova Password" styleClass="field-label"/>
                <PasswordField fx:id="confermaNuovaPasswordField" maxWidth="Infinity" prefHeight="44" promptText="Conferma Nuova Password"/>
                <Button maxWidth="Infinity" prefHeight="48" text="Conferma" onAction="#ClickConferma"
                        styleClass="primary-login-button"/>
            </VBox>
        </VBox>
    </center>
    <bottom>
    <HBox alignment="BOTTOM_LEFT" BorderPane.alignment="BOTTOM_LEFT">
        <Button text="Torna indietro" onAction="#ClickIndietro"/>
    </HBox>
    </bottom>
</BorderPane>
