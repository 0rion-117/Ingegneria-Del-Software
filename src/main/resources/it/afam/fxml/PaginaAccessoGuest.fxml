<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.ViewPaginaAccessoGuest" styleClass="root">
    <padding><Insets top="42" right="42" bottom="42" left="42"/></padding>
    <center>
        <VBox alignment="CENTER" maxWidth="980" spacing="14" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="6">
                <Label text="Contenuti condivisi" styleClass="form-title"/>
                <Label text="Materiali disponibili tramite link dedicato" styleClass="form-subtitle"/>
            </VBox>
            <ListView fx:id="contenutiList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
    <bottom>
    <HBox alignment="BOTTOM_LEFT" BorderPane.alignment="BOTTOM_LEFT">
        <Button text="Chiudi" onAction="#ClickChiudi"/>
    </HBox>
    </bottom>
</BorderPane>
