<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.GestioneCartelleController" styleClass="root">
    <top>
        <HBox alignment="CENTER" spacing="16">
            <padding><Insets top="18" right="28" bottom="8" left="28"/></padding>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Cartelle" styleClass="form-title"/>
                <Label text="Organizza e condividi i contenuti del portfolio" styleClass="form-subtitle"/>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="8">
                <Button text="Crea Cartella" onAction="#ClickCreaCartella"/>
            </HBox>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" maxWidth="980" spacing="10" BorderPane.alignment="CENTER">
            <ListView fx:id="cartelleList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="8">
            <padding><Insets top="8" right="28" bottom="22" left="28"/></padding>
            <Button text="Torna indietro" onAction="#ClickIndietro"/>
            <Button text="Modifica Cartella" onAction="#ClickModificaCartella"/>
            <Button text="Elimina Cartella" onAction="#ClickEliminaCartella"/>
            <Button text="Condividi Cartella" onAction="#ClickCondividiCartella"/>
            <Button text="Visualizza Statistiche" onAction="#ClickVisualizzaStatistiche"/>
        </HBox>
    </bottom>
</BorderPane>
