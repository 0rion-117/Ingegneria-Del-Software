<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.afam.view.FormContenutoController" styleClass="root">
    <fx:define>
        <ToggleGroup fx:id="visibilitaGroup"/>
    </fx:define>
    <padding><Insets top="42" right="42" bottom="42" left="42"/></padding>
    <center>
        <VBox alignment="CENTER" maxWidth="720" spacing="16" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="6">
                <Label text="Contenuto" styleClass="form-title"/>
                <Label text="Carica o aggiorna il materiale del portfolio" styleClass="form-subtitle"/>
            </VBox>
            <VBox maxWidth="680" spacing="10">
                <Label text="File" styleClass="field-label"/>
                <HBox alignment="CENTER" spacing="10">
                    <TextField fx:id="fileField" maxWidth="Infinity" prefHeight="42" promptText="File" HBox.hgrow="ALWAYS"/>
                    <Button minWidth="150" prefHeight="42" text="Seleziona File" onAction="#SelezionaFile"/>
                </HBox>
                <Label text="Titolo" styleClass="field-label"/>
                <TextField fx:id="titoloField" maxWidth="Infinity" prefHeight="42" promptText="Titolo"/>
                <Label text="Descrizione" styleClass="field-label"/>
                <TextArea fx:id="descrizioneArea" maxHeight="170" maxWidth="Infinity" prefRowCount="6" promptText="Descrizione" wrapText="true"/>
                <Label text="Visibilita" styleClass="field-label"/>
                <HBox alignment="CENTER_LEFT" spacing="18">
                    <RadioButton fx:id="pubblicoRadio" text="Pubblico" toggleGroup="$visibilitaGroup"/>
                    <RadioButton fx:id="privatoRadio" text="Privato" toggleGroup="$visibilitaGroup"/>
                </HBox>
                <Label fx:id="statoInvioLabel" styleClass="form-subtitle"/>
                <Button fx:id="confermaButton" maxWidth="Infinity" prefHeight="48" text="Conferma" onAction="#ClickConferma"
                        styleClass="primary-login-button"/>
            </VBox>
        </VBox>
    </center>
    <bottom>
    <HBox alignment="BOTTOM_LEFT" BorderPane.alignment="BOTTOM_LEFT">
        <Button text="Torna indietro" onAction="#ClickIndietro"/>
    </HBox>
    </bottom>
</BorderPane>
